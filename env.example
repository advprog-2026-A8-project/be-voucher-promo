# PostgreSQL connection for Voucher & Promo service
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=voucherdb
POSTGRES_USER=voucheruser
POSTGRES_PASSWORD=voucherpass

# JWT secret used to protect admin voucher endpoints
# Must match the Authentication service issuer secret
JWT_SECRET=replace-with-the-shared-jwt-secret
JWT_EXPIRATION=86400000